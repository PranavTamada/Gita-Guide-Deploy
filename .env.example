# Bhagavad Gita AI — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash-lite

# LLM call timeout in milliseconds
GEMINI_TIMEOUT_MS=30000

# Number of candidate verses to retrieve before KG re-ranking
TOP_K_RETRIEVAL=9

# Final number of verses shown to the user
TOP_K_FINAL=3

# Express server port
PORT=3000
