# Bhagavad Gita AI — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ollama model to use (tinyllama is lightweight; try mistral or llama3 for higher quality)
OLLAMA_MODEL=tinyllama

# LLM call timeout in milliseconds
OLLAMA_TIMEOUT_MS=30000

# Number of candidate verses to retrieve before KG re-ranking
TOP_K_RETRIEVAL=9

# Final number of verses shown to the user
TOP_K_FINAL=3

# Express server port
PORT=3000
